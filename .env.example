# Optional: override API base URL for the frontend.
# By default, Vite dev proxy routes /api to http://localhost:8080.
VITE_API_BASE_URL=

# Backend configuration
PORT=8080
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/peopleops

# RAG settings
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=4

# Embeddings: use 'local' for deterministic local vectors, or 'openai' for API embeddings.
EMBEDDINGS_PROVIDER=local
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
