{
  "name": "mobility-ai-platform",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "backend:dev": "node --watch backend/server.js",
    "backend:start": "node backend/server.js",
    "backend:db:up": "docker compose up -d postgres",
    "backend:db:down": "docker compose down",
    "backend:db:init": "node backend/scripts/init-db.js",
    "backend:db:seed": "node backend/scripts/seed-db.js",
    "backend:rag:index": "node backend/scripts/reindex-rag.js",
    "backend:setup": "npm run backend:db:init && npm run backend:db:seed && npm run backend:rag:index",
    "build": "tsc -b && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "typescript": "^5.2.2",
    "vite": "^5.3.4"
  }
}
